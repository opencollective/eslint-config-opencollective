{
  "name": "eslint-config-opencollective",
  "version": "7.0.0",
  "description": "Base ESLint config shared across OpenCollective projects (node and browser)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opencollective/eslint-config-opencollective.git"
  },
  "main": "index.js",
  "scripts": {
    "prettier": "prettier \"*.@(js|cjs|json|md)\"",
    "prettier:write": "npm run prettier -- --write",
    "prettier:check": "npm run prettier -- --list-different",
    "test": "npm run prettier:check && npm run test:unit",
    "test:unit": "node --test test/*.test.js",
    "prepare": "husky"
  },
  "author": {
    "name": "Open Collective, Inc.",
    "email": "team@opencollective.com"
  },
  "contributors": [
    "Xavier Damman <xdamman@opencollective.com>",
    "Aseem Sood <aseem@opencollective.com>",
    "François Hodierne <francois@opencollective.com>",
    "Marco Barcellos <marco@opencollective.com>",
    "Arnaud Bénard",
    "Sébastien Dubois"
  ],
  "license": "MIT",
  "files": [
    "eslint-main.config.cjs",
    "eslint-node.config.cjs",
    "eslint-react.config.cjs"
  ],
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@eslint/compat": "^2.1.0"
  },
  "peerDependencies": {
    "@eslint/js": ">=10.0.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": ">=10.0.0",
    "eslint-plugin-import": ">=2.0.0",
    "eslint-plugin-n": ">=18.0.0",
    "eslint-plugin-react": ">=7.0.0",
    "eslint-plugin-simple-import-sort": ">=12.0.0",
    "globals": ">=15.0.0",
    "typescript": ">=5.0.0",
    "typescript-eslint": "^8.61.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^18.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "lint-staged": {
    "*.{js,json,md,cjs}": [
      "prettier --write",
      "git add"
    ]
  },
  "overrides": {
    "eslint-plugin-import": {
      "eslint": "$eslint"
    },
    "eslint-plugin-react": {
      "eslint": "$eslint"
    }
  }
}
